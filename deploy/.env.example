# Copy this file to `.env` and fill in the two required values.
#
#   cp .env.example .env

# Public hostname that resolves (via DNS A/AAAA) to this docker host.
# Caddy will obtain a Let's Encrypt certificate for this name on first start.
DOMAIN=updates.example.com

# Contact email for Let's Encrypt account registration and expiry notices.
ACME_EMAIL=ops@example.com
